{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["@electron-forge/plugin-vite/forge-vite-env"]
  },
  "include": [
    "src/**/*",
    "electron-expose.config.ts",
    "forge.config.ts",
    "vite.*.config.ts"
  ]
}
