{
  "name": "@electron-expose/calculator-example",
  "productName": "Electron Expose Calculator",
  "version": "0.1.0",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "generate": "electron-expose generate --config electron-expose.config.ts",
    "start": "pnpm run generate && electron-forge start",
    "package": "pnpm run generate && electron-forge package",
    "make": "pnpm run generate && electron-forge make",
    "typecheck": "pnpm run generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron-expose": "workspace:*",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^42.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
